# PHLedger Environment Variables
# Copy to .env.local and fill in for Supabase cloud mode (optional).
# Without these, PHLedger runs in local CSV-only mode.

# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-secret-key

# Optional: override the bank_data directory path
# BANK_DATA_PATH=/custom/path/to/bank_data

# ── Supabase setup steps ──────────────────────────────────
# 1. Create free project at https://app.supabase.com
# 2. Go to SQL Editor → paste contents of supabase/migrations/001_init.sql → Run
# 3. Copy Project URL + service_role key from Project Settings → API
# 4. Add to Vercel: Dashboard → Project → Settings → Environment Variables
#    OR: vercel env add SUPABASE_URL && vercel env add SUPABASE_KEY
# ─── SilverConnect Global (upstream platform config) ───────────────
# Optional: URL of SilverConnect API to auto-sync platform fee settings
# If not set, PHLedger uses the locally stored/default config
SILVERCONNECT_API_URL=https://silverconnect-global.vercel.app/api/platform/settings
SILVERCONNECT_API_KEY=<your-api-key-here>
