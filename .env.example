# PHLedger Environment Variables
# Copy to .env and fill in for Supabase cloud mode (optional).
# Without these, PHLedger runs in local CSV-only mode.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-secret-key

# Optional: override bank_data directory path
# BANK_DATA_PATH=/custom/path/to/bank_data
